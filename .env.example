# ============================================================
# Multi-Agent Competitive Intelligence System - 环境变量模板
# ============================================================
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# LLM Configuration - 使用豆包（字节豆包大模型）
LLM_PROVIDER=doubao
LLM_MODEL=YOUR_MODEL_ENDPOINT_ID
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 豆包/火山引擎 Ark
ARK_API_KEY=your-ark-api-key-here
DOUBAO_MODEL_ID=YOUR_MODEL_ENDPOINT_ID
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MAX_CONTEXT_TOKENS=32000
DOUBAO_TRUNCATION_STRATEGY=tail

# 通义千问（回退兼容，可选）
DASHSCOPE_API_KEY=your-dashscope-key-here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ci-agents

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=ci-

# Redis
REDIS_URL=redis://localhost:6379/0

# Notifications
SLACK_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_TOKEN
FEISHU_WEBHOOK_SECRET=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=

# Pipeline Tuning
MONITOR_INTERVAL_MINUTES=60
QUALITY_THRESHOLD=7.0
MAX_REFLEXION_RETRIES=3
