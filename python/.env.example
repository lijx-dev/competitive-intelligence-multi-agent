# ============================================================
# Multi-Agent Competitive Intelligence System - Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# ── LLM Configuration（主 Provider：豆包大模型）────────────────
# Provider 可选: doubao（默认）/ tongyi（回退）
LLM_PROVIDER=doubao
LLM_MODEL=doubao-seed-1-8-251228
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 豆包/火山引擎 Ark（比赛指定模型）
ARK_API_KEY=your_volcengine_ark_api_key_here
DOUBAO_MODEL_ID=doubao-seed-1-8-251228
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MAX_CONTEXT_TOKENS=32000
DOUBAO_TRUNCATION_STRATEGY=tail

# 通义千问（回退兼容，比赛期间无需配置）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ci-agents

# ── Elasticsearch ────────────────────────────────────────────
ES_URL=http://localhost:9200
ES_INDEX_PREFIX=ci-

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Notifications ────────────────────────────────────────────
SLACK_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_PASSWORD=

# ── Pipeline Tuning ──────────────────────────────────────────
MONITOR_INTERVAL_MINUTES=60
QUALITY_THRESHOLD=7.0
MAX_REFLEXION_RETRIES=3

# ── 飞书CLI全局总调度官（可选，未配置时优雅降级）────────────
# 飞书机器人 Webhook（告警 + 报告推送）
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
# 全局推送开关：设为false可一键关闭所有自动推送（默认true）
FEISHU_AUTO_PUSH_ENABLED=true
# 飞书多维表格（Bitable自动同步，需要 lark-cli + 飞书应用授权）
FEISHU_BITABLE_APP_TOKEN=
# 飞书云文档生成（需要 lark-cli: pip install lark-cli）
FEISHU_DOC_FOLDER_TOKEN=
